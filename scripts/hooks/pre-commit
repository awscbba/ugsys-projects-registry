#!/usr/bin/env bash
set -euo pipefail
RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' NC='\033[0m'
echo "" && echo "🔍 Running pre-commit checks..." && echo ""
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$BRANCH" == "main" ]]; then
  echo -e "${RED}✗ Direct commits to 'main' are not allowed.${NC}"; exit 1
fi
echo -e "${YELLOW}── Ruff lint ──${NC}"
if just --quiet lint 2>&1; then
  echo -e "  ${GREEN}✓ ruff lint${NC}"
else
  echo -e "  ${RED}✗ ruff lint failed — run: just lint${NC}"; exit 1
fi
echo -e "${YELLOW}── Ruff format ──${NC}"
if just --quiet format-check 2>&1; then
  echo -e "  ${GREEN}✓ ruff format${NC}"
else
  echo -e "  ${RED}✗ ruff format failed — run: just format${NC}"; exit 1
fi
echo -e "${YELLOW}── Unit tests ──${NC}"
if just test 2>&1; then
  echo -e "  ${GREEN}✓ unit tests${NC}"
else
  echo -e "  ${RED}✗ unit tests failed — run: just test${NC}"; exit 1
fi
echo ""
echo -e "${GREEN}✓ All pre-commit checks passed.${NC}" && echo ""
exit 0
